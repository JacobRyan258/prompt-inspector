# Prompt Inspector proxy — drop-in replacement for https://api.openai.com.
# Point your OpenAI SDK at http://localhost:4000/v1.

# Port and host the proxy listens on.
PORT=4000
# HOST=0.0.0.0

# Upstream OpenAI-compatible API base URL (no trailing slash needed).
OPENAI_BASE_URL=https://api.openai.com

# API key for the upstream. Live mode needs BOTH this key and a model mapping
# for the routed tier below; otherwise that request runs in demo mode.
# Callers can also send their own Authorization header, which takes precedence.
OPENAI_API_KEY=

# Tier → upstream model mapping: which real model each tier rides on.
# Unset tiers always run in demo mode.
INSPECTOR_MODEL_LUNA=gpt-4.1-mini
INSPECTOR_MODEL_TERRA=gpt-4.1
INSPECTOR_MODEL_SOL=o3

# Shared-secret gate for a publicly hosted proxy. When set, every /v1/*
# request must send `Authorization: Bearer <this key>` (/health stays open),
# and the caller's Authorization is no longer forwarded upstream — the
# proxy's own OPENAI_API_KEY above is the only upstream credential.
# Leave unset for local use (proxy stays open on localhost).
# PROXY_API_KEY=

# Override the SQLite log location.
# Defaults to <repo-root>/.data/prompt-inspector.db.
# PROMPT_INSPECTOR_DB=/path/to/prompt-inspector.db
