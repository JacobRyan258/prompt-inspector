# Prompt Inspector — root env (also read by the proxy; apps/proxy/.env takes
# precedence for proxy-only settings — see apps/proxy/.env.example for docs).

# --- Upstream (leave unset for fully-labeled demo mode) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com

# --- Tier → upstream model mapping (the tiers are routing vocabulary;
#     map them to whatever real models your provider offers) ---
# INSPECTOR_MODEL_LUNA=gpt-4.1-mini
# INSPECTOR_MODEL_TERRA=gpt-4.1
# INSPECTOR_MODEL_SOL=o3

# --- Storage (defaults to <repo>/.data/prompt-inspector.db) ---
# PROMPT_INSPECTOR_DB=/path/to/prompt-inspector.db
