# Prompt Inspector — root env (also read by the proxy; apps/proxy/.env takes
# precedence for proxy-only settings — see apps/proxy/.env.example for docs).

# --- Upstream (leave unset for fully-labeled demo mode) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com

# --- Tier → upstream model mapping (the tiers are routing vocabulary;
#     map them to whatever real models your provider offers) ---
# INSPECTOR_MODEL_LUNA=gpt-4.1-mini
# INSPECTOR_MODEL_TERRA=gpt-4.1
# INSPECTOR_MODEL_SOL=o3

# --- Storage ---
# Zero-config default: local SQLite at <repo>/.data/prompt-inspector.db
# (auto-created). Set DATABASE_URL to store in Supabase Postgres instead —
# use the transaction pooler (port 6543); the app connects with
# prepare:false, ssl:"require" and a small pool.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# --- Web → proxy (only for a hosted proxy; local dev uses localhost:4000) ---
# Base URL of a publicly hosted proxy, and the shared secret it gates on
# (must match the proxy's PROXY_API_KEY). Also settable in Vercel env.
# PROMPT_INSPECTOR_PROXY_URL=https://proxy.example.com
# PROMPT_INSPECTOR_PROXY_KEY=
# PROMPT_INSPECTOR_DB=/path/to/prompt-inspector.db
